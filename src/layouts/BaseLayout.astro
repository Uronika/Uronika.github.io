---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { siteProfile } from "@/data/site";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  pageClass?: string;
  canonicalPath?: string;
  redirectTo?: string;
}

const {
  title = `${siteProfile.alias}｜个人作品与职业档案`,
  description = siteProfile.introduction,
  image = "/og-default.png",
  type = "website",
  noindex = false,
  pageClass,
  canonicalPath,
  redirectTo
} = Astro.props;

const canonical = new URL(canonicalPath ?? Astro.url.pathname, Astro.site ?? siteProfile.siteUrl);
const socialImage = new URL(image, Astro.site ?? siteProfile.siteUrl);
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteProfile.realName,
  alternateName: siteProfile.alias,
  url: siteProfile.siteUrl,
  jobTitle: siteProfile.role,
  sameAs: siteProfile.socials.flatMap((social) => (social.href ? [social.href] : []))
};
---

<!doctype html>
<html lang="zh-CN" class={pageClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B090A" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    {redirectTo && <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="Uronika" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <div class="ambient ambient--top" aria-hidden="true"></div>
    <div class="ambient ambient--bottom" aria-hidden="true"></div>
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
