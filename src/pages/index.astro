---
import { getCollection } from "astro:content";
import ContactPreview from "@/components/ContactPreview.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";
import HeroCollage from "@/components/HeroCollage.astro";
import HeroSectionPager from "@/components/HeroSectionPager.astro";
import HomeSectionNav from "@/components/HomeSectionNav.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SkillGroups from "@/components/SkillGroups.astro";
import WorkGrid from "@/components/WorkGrid.astro";
import { resume, siteProfile } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getGithubSnapshot } from "@/lib/github";

const works = (await getCollection("works"))
  .filter((work) => work.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99));
const githubSnapshot = await getGithubSnapshot();
---

<BaseLayout pageClass="home-snap">
  <HomeSectionNav />
  <HeroSectionPager />

  <section class="hero home-section section-shell" id="home" data-home-section>
    <div class="hero-copy">
      <div class="hero-kicker">
        <span class="status-dot" aria-hidden="true"></span>
        {siteProfile.availability}
      </div>
      <p class="hero-identity">{siteProfile.realName} <span>/</span> {siteProfile.alias}</p>
      <h1>
        <span class="hero-line">用代码构建，</span>
        <span class="hero-line">用作品<em>表达。</em></span>
      </h1>
      <p class="hero-role">{siteProfile.role}</p>
      <p class="hero-introduction">{siteProfile.introduction}</p>
      <div class="hero-actions">
        <a class="button button--primary" href="#featured-works">查看精选作品</a>
        <a class="button button--secondary" href="/resume/">查看完整简历</a>
      </div>
      <div class="hero-meta">
        <span>LOC / {siteProfile.location}</span>
        <span>FOCUS / DEV · GAME · VIDEO · IMAGE</span>
      </div>
    </div>
    <HeroCollage works={works} />
  </section>

  <section class="page-section home-section section-shell" id="capabilities" data-home-section>
    <SectionHeading
      eyebrow="01 / Capabilities"
      title="先说明我能做什么，再用作品给出证据。"
      description="技能不会使用主观进度条，而是按领域组织并关联到真实项目。当前内容均明确标记为待补充。"
    />
    <SkillGroups />
  </section>

  <section class="page-section home-section section-shell" id="featured-works" data-home-section>
    <SectionHeading
      eyebrow="02 / Selected Works"
      title="跨越开发与创作的六个精选位置。"
      description="首版用占位作品验证完整布局；正式发布前，每一项都将替换为真实作品、准确介绍和定制封面。"
      actionHref="/works/"
      actionLabel="浏览全部作品"
    />
    <WorkGrid works={works} githubRepositories={githubSnapshot.repositories} featured />
  </section>

  <section class="page-section home-section section-shell" id="experience" data-home-section>
    <SectionHeading
      eyebrow="03 / Experience"
      title="经历不是清单，而是能力形成的路径。"
      description="工作、实习与教育资料将在确认后按时间线补充，并关联对应的项目证据。"
      actionHref="/resume/"
      actionLabel="查看网页简历"
    />
    <ExperienceTimeline entries={resume.experience} />
  </section>

  <section class="page-section home-section section-shell" id="contact" data-home-section>
    <ContactPreview />
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-top: 120px;
    padding-bottom: 56px;
    isolation: isolate;
  }

  .hero::before,
  .hero::after {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    content: "";
    pointer-events: none;
    transform: translateX(-50%);
  }

  .hero::before {
    z-index: 2;
    background:
      radial-gradient(
        ellipse 54% 76% at 86% 4%,
        rgba(255, 195, 151, 0.5) 0%,
        rgba(255, 107, 53, 0.34) 24%,
        rgba(255, 77, 90, 0.12) 48%,
        transparent 74%
      ),
      conic-gradient(
        from 198deg at 88% -12%,
        transparent 0deg,
        rgba(255, 136, 78, 0.04) 18deg,
        rgba(255, 107, 53, 0.24) 31deg,
        rgba(255, 77, 90, 0.085) 46deg,
        transparent 62deg
      );
    filter: blur(4px);
  }

  .hero::after {
    z-index: 1;
    background:
      linear-gradient(
        90deg,
        rgba(5, 4, 4, 0.995) 0%,
        rgba(6, 5, 5, 0.97) 30%,
        rgba(8, 6, 6, 0.88) 50%,
        rgba(9, 6, 5, 0.6) 72%,
        rgba(9, 6, 5, 0.38) 100%
      ),
      linear-gradient(180deg, rgba(11, 9, 10, 0.12), rgba(11, 9, 10, 0.52));
  }

  .hero-copy {
    position: relative;
    z-index: 4;
    width: min(56%, 680px);
  }

  .hero :global(.hero-collage) {
    position: absolute;
    z-index: 3;
    top: 50%;
    right: calc(50% - 50vw + 48px);
    width: min(78vw, 1120px);
    min-height: 730px;
    transform: translateY(-50%);
  }

  .hero :global(.hero-tile span) {
    right: 16px;
    bottom: 14px;
    left: 16px;
    font-size: 0.8rem;
  }

  .hero :global(.hero-orbit) {
    width: 470px;
    height: 470px;
  }

  .hero-kicker {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 9px 14px;
    margin-bottom: 38px;
    color: #cbbab1;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: var(--color-ember);
    border-radius: 50%;
    box-shadow: 0 0 16px var(--color-ember);
  }

  .hero-identity {
    margin-bottom: 14px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .hero-identity span {
    margin-inline: 8px;
    color: var(--color-ember);
  }

  h1 {
    display: grid;
    margin-bottom: 20px;
    font-size: clamp(4.05rem, 6.7vw, 5.8rem);
    letter-spacing: -0.075em;
  }

  .hero-line {
    white-space: nowrap;
  }

  h1 em {
    color: transparent;
    background: linear-gradient(120deg, #ffa173, var(--color-ember) 48%, var(--color-coral));
    background-clip: text;
    -webkit-background-clip: text;
    font-style: normal;
  }

  .hero-role {
    margin-bottom: 12px;
    color: #ffae8c;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .hero-introduction {
    max-width: 660px;
    margin-bottom: 32px;
    color: var(--color-muted);
    font-size: 1.16rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions :global(.button) {
    min-height: 54px;
    padding: 13px 24px;
    font-size: 0.99rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    padding-top: 40px;
    margin-top: 42px;
    color: #7f716c;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .page-section.home-section {
    --section-light-x: 18%;
    --section-light-y: 42%;
    --section-light-core: rgba(255, 107, 53, 0.21);
    --section-light-mid: rgba(255, 77, 90, 0.072);
    isolation: isolate;
  }

  .page-section.home-section::after {
    position: absolute;
    z-index: -1;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    content: "";
    pointer-events: none;
    background: radial-gradient(
      ellipse 52% 46% at var(--section-light-x) var(--section-light-y),
      var(--section-light-core) 0%,
      var(--section-light-mid) 36%,
      transparent 74%
    );
    transform: translateX(-50%);
  }

  #featured-works {
    --section-light-x: 84%;
    --section-light-y: 36%;
    --section-light-core: rgba(255, 107, 53, 0.176);
    --section-light-mid: rgba(255, 157, 101, 0.056);
  }

  #experience {
    --section-light-x: 16%;
    --section-light-y: 56%;
    --section-light-core: rgba(255, 77, 90, 0.16);
    --section-light-mid: rgba(255, 107, 53, 0.056);
  }

  #contact {
    --section-light-x: 78%;
    --section-light-y: 64%;
    --section-light-core: rgba(255, 126, 73, 0.192);
    --section-light-mid: rgba(255, 77, 90, 0.064);
  }

  @media (min-width: 981px) and (max-height: 780px) {
    .hero {
      padding-top: 100px;
      padding-bottom: 36px;
    }

    .hero-kicker {
      margin-bottom: 22px;
    }

    h1 {
      margin-bottom: 16px;
      font-size: clamp(3.55rem, 6vw, 5rem);
    }

    .hero-introduction {
      margin-bottom: 22px;
      font-size: 1.04rem;
    }

    .hero-actions :global(.button) {
      min-height: 48px;
      padding: 11px 20px;
      font-size: 0.92rem;
    }

    .hero-meta {
      padding-top: 26px;
      margin-top: 28px;
    }

    .hero :global(.hero-collage) {
      right: calc(50% - 50vw + 48px);
      width: min(72vw, 1020px);
      min-height: 620px;
    }

    .hero :global(.hero-orbit) {
      width: 410px;
      height: 410px;
    }
  }

  @media (max-width: 980px) {
    .hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 48px;
      min-height: auto;
      padding-top: 150px;
    }

    .hero::before {
      opacity: 0.6;
      background: radial-gradient(
        ellipse 90% 48% at 82% 0%,
        rgba(255, 184, 135, 0.46) 0%,
        rgba(255, 107, 53, 0.18) 42%,
        transparent 74%
      );
      filter: blur(8px);
    }

    .hero::after {
      display: none;
    }

    .hero-copy {
      width: auto;
      max-width: 720px;
    }

    .hero-kicker {
      padding: 8px 12px;
      margin-bottom: 34px;
      font-size: 0.68rem;
    }

    .hero-identity {
      font-size: 0.72rem;
    }

    h1 {
      font-size: clamp(3.6rem, 6vw, 5.1rem);
    }

    .hero-role {
      font-size: 0.78rem;
    }

    .hero-introduction {
      max-width: 610px;
      margin-bottom: 28px;
      font-size: 1.04rem;
    }

    .hero-actions :global(.button) {
      min-height: 48px;
      padding: 11px 20px;
      font-size: 0.92rem;
    }

    .hero-meta {
      padding-top: 36px;
      margin-top: 38px;
      font-size: 0.64rem;
    }

    .hero :global(.hero-collage) {
      position: relative;
      inset: auto;
      width: 100%;
      min-height: 560px;
      transform: none;
    }

    .hero :global(.hero-tile span) {
      right: 14px;
      bottom: 12px;
      left: 14px;
      font-size: 0.72rem;
    }

    .hero :global(.hero-orbit) {
      width: 410px;
      height: 410px;
    }

    .page-section.home-section::after {
      opacity: 0.6;
    }
  }

  @media (max-width: 760px) {
    .hero {
      gap: 48px;
      min-height: auto;
      padding-top: 120px;
      padding-bottom: 30px;
    }

    h1 {
      font-size: clamp(3.25rem, 14vw, 4.2rem);
    }

    .hero-meta {
      display: grid;
    }

    .hero :global(.hero-collage) {
      min-height: auto;
    }
  }
</style>
