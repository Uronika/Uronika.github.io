---
import { getCollection } from "astro:content";
import ContactPreview from "@/components/ContactPreview.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";
import HeroCollage from "@/components/HeroCollage.astro";
import HomeSectionNav from "@/components/HomeSectionNav.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SkillGroups from "@/components/SkillGroups.astro";
import WorkGrid from "@/components/WorkGrid.astro";
import { resume, siteProfile } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getGithubSnapshot } from "@/lib/github";

const works = (await getCollection("works"))
  .filter((work) => work.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99));
const githubSnapshot = await getGithubSnapshot();
---

<BaseLayout pageClass="home-snap">
  <HomeSectionNav />

  <section class="hero home-section section-shell" id="home" data-home-section>
    <div class="hero-copy">
      <div class="hero-kicker">
        <span class="status-dot" aria-hidden="true"></span>
        {siteProfile.availability}
      </div>
      <p class="hero-identity">{siteProfile.realName} <span>/</span> {siteProfile.alias}</p>
      <h1>
        <span class="hero-line">用代码构建，</span>
        <span class="hero-line">用作品<em>表达。</em></span>
      </h1>
      <p class="hero-role">{siteProfile.role}</p>
      <p class="hero-introduction">{siteProfile.introduction}</p>
      <div class="hero-actions">
        <a class="button button--primary" href="#featured-works">查看精选作品</a>
        <a class="button button--secondary" href="/resume/">查看完整简历</a>
      </div>
      <div class="hero-meta">
        <span>LOC / {siteProfile.location}</span>
        <span>FOCUS / DEV · GAME · VIDEO · IMAGE</span>
      </div>
    </div>
    <HeroCollage works={works} />
  </section>

  <section class="page-section home-section section-shell" id="capabilities" data-home-section>
    <SectionHeading
      eyebrow="01 / Capabilities"
      title="先说明我能做什么，再用作品给出证据。"
      description="技能不会使用主观进度条，而是按领域组织并关联到真实项目。当前内容均明确标记为待补充。"
    />
    <SkillGroups />
  </section>

  <section class="page-section home-section section-shell" id="featured-works" data-home-section>
    <SectionHeading
      eyebrow="02 / Selected Works"
      title="跨越开发与创作的六个精选位置。"
      description="首版用占位作品验证完整布局；正式发布前，每一项都将替换为真实作品、准确介绍和定制封面。"
      actionHref="/works/"
      actionLabel="浏览全部作品"
    />
    <WorkGrid works={works} githubRepositories={githubSnapshot.repositories} featured />
  </section>

  <section class="page-section home-section section-shell" id="experience" data-home-section>
    <SectionHeading
      eyebrow="03 / Experience"
      title="经历不是清单，而是能力形成的路径。"
      description="工作、实习与教育资料将在确认后按时间线补充，并关联对应的项目证据。"
      actionHref="/resume/"
      actionLabel="查看网页简历"
    />
    <ExperienceTimeline entries={resume.experience} />
  </section>

  <section class="page-section home-section section-shell" id="contact" data-home-section>
    <ContactPreview />
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-top: 120px;
    padding-bottom: 56px;
    isolation: isolate;
  }

  .hero::after {
    position: absolute;
    z-index: 2;
    inset: 0 auto 0 -12vw;
    width: 68%;
    content: "";
    pointer-events: none;
    background: linear-gradient(90deg, var(--color-bg) 35%, rgba(11, 9, 10, 0.94) 68%, transparent 100%);
  }

  .hero-copy {
    position: relative;
    z-index: 3;
    width: min(52%, 610px);
  }

  .hero :global(.hero-collage) {
    position: absolute;
    z-index: 1;
    top: 50%;
    right: -110px;
    width: min(70vw, 980px);
    min-height: 650px;
    transform: translateY(-50%);
  }

  .hero-kicker {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 8px 12px;
    margin-bottom: 34px;
    color: #cbbab1;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: var(--color-ember);
    border-radius: 50%;
    box-shadow: 0 0 16px var(--color-ember);
  }

  .hero-identity {
    margin-bottom: 14px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .hero-identity span {
    margin-inline: 8px;
    color: var(--color-ember);
  }

  h1 {
    display: grid;
    margin-bottom: 20px;
    font-size: clamp(3.6rem, 6vw, 5.1rem);
    letter-spacing: -0.075em;
  }

  .hero-line {
    white-space: nowrap;
  }

  h1 em {
    color: transparent;
    background: linear-gradient(120deg, #ffa173, var(--color-ember) 48%, var(--color-coral));
    background-clip: text;
    -webkit-background-clip: text;
    font-style: normal;
  }

  .hero-role {
    margin-bottom: 12px;
    color: #ffae8c;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .hero-introduction {
    max-width: 610px;
    margin-bottom: 28px;
    color: var(--color-muted);
    font-size: 1.04rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    padding-top: 36px;
    margin-top: 38px;
    color: #7f716c;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 980px) {
    .hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 48px;
      min-height: auto;
      padding-top: 150px;
    }

    .hero::after {
      display: none;
    }

    .hero-copy {
      width: auto;
      max-width: 720px;
    }

    .hero :global(.hero-collage) {
      position: relative;
      inset: auto;
      width: 100%;
      min-height: 560px;
      transform: none;
    }
  }

  @media (max-width: 760px) {
    .hero {
      gap: 48px;
      min-height: auto;
      padding-top: 120px;
      padding-bottom: 30px;
    }

    h1 {
      font-size: clamp(3.25rem, 14vw, 4.2rem);
    }

    .hero-meta {
      display: grid;
    }

    .hero :global(.hero-collage) {
      min-height: auto;
    }
  }
</style>
