---
import { getCollection } from "astro:content";
import ContactPanel from "@/components/ContactPanel.astro";
import ExperienceTimeline from "@/components/ExperienceTimeline.astro";
import HeroCollage from "@/components/HeroCollage.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SkillGroups from "@/components/SkillGroups.astro";
import WorkGrid from "@/components/WorkGrid.astro";
import { resume, siteProfile } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getGithubSnapshot } from "@/lib/github";

const works = (await getCollection("works"))
  .filter((work) => work.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99));
const githubSnapshot = await getGithubSnapshot();
---

<BaseLayout>
  <section class="hero section-shell">
    <div class="hero-copy">
      <div class="hero-kicker">
        <span class="status-dot" aria-hidden="true"></span>
        {siteProfile.availability}
      </div>
      <p class="hero-identity">{siteProfile.realName} <span>/</span> {siteProfile.alias}</p>
      <h1>
        <span class="hero-line">用代码构建，</span>
        <span class="hero-line">用作品<em>表达。</em></span>
      </h1>
      <p class="hero-role">{siteProfile.role}</p>
      <p class="hero-introduction">{siteProfile.introduction}</p>
      <div class="hero-actions">
        <a class="button button--primary" href="#featured-works">查看精选作品</a>
        <a class="button button--secondary" href="/resume/">查看完整简历</a>
      </div>
      <div class="hero-meta">
        <span>LOC / {siteProfile.location}</span>
        <span>FOCUS / DEV · GAME · VIDEO · IMAGE</span>
      </div>
    </div>
    <HeroCollage works={works} />
  </section>

  <section class="page-section section-shell" id="capabilities">
    <SectionHeading
      eyebrow="01 / Capabilities"
      title="先说明我能做什么，再用作品给出证据。"
      description="技能不会使用主观进度条，而是按领域组织并关联到真实项目。当前内容均明确标记为待补充。"
    />
    <SkillGroups />
  </section>

  <section class="page-section section-shell" id="featured-works">
    <SectionHeading
      eyebrow="02 / Selected Works"
      title="跨越开发与创作的六个精选位置。"
      description="首版用占位作品验证完整布局；正式发布前，每一项都将替换为真实作品、准确介绍和定制封面。"
      actionHref="/works/"
      actionLabel="浏览全部作品"
    />
    <WorkGrid works={works} githubRepositories={githubSnapshot.repositories} featured />
  </section>

  <section class="page-section section-shell">
    <SectionHeading
      eyebrow="03 / Experience"
      title="经历不是清单，而是能力形成的路径。"
      description="工作、实习与教育资料将在确认后按时间线补充，并关联对应的项目证据。"
      actionHref="/resume/"
      actionLabel="查看网页简历"
    />
    <ExperienceTimeline entries={resume.experience} />
  </section>

  <section class="page-section section-shell">
    <div class="account-teaser glass">
      <div>
        <p class="eyebrow">04 / Elsewhere</p>
        <h2>在其他平台继续了解我的公开创作。</h2>
      </div>
      <div class="account-teaser__links">
        {siteProfile.socials.map((social) => social.href ? (
          <a href={social.href} target="_blank" rel="noreferrer">{social.label}<span>{social.handle} ↗</span></a>
        ) : (
          <span>{social.label}<small>{social.handle}</small></span>
        ))}
        <a class="text-link" href="/accounts/">查看账号档案 <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <section class="page-section section-shell">
    <ContactPanel />
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(480px, 1.08fr);
    gap: clamp(36px, 7vw, 96px);
    align-items: center;
    min-height: 100svh;
    padding-top: 120px;
    padding-bottom: 56px;
  }

  .hero-kicker {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 8px 12px;
    margin-bottom: 34px;
    color: #cbbab1;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: var(--color-ember);
    border-radius: 50%;
    box-shadow: 0 0 16px var(--color-ember);
  }

  .hero-identity {
    margin-bottom: 14px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .hero-identity span {
    margin-inline: 8px;
    color: var(--color-ember);
  }

  h1 {
    display: grid;
    margin-bottom: 20px;
    font-size: clamp(3.6rem, 6vw, 5.1rem);
    letter-spacing: -0.075em;
  }

  .hero-line {
    white-space: nowrap;
  }

  h1 em {
    color: transparent;
    background: linear-gradient(120deg, #ffa173, var(--color-ember) 48%, var(--color-coral));
    background-clip: text;
    -webkit-background-clip: text;
    font-style: normal;
  }

  .hero-role {
    margin-bottom: 12px;
    color: #ffae8c;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .hero-introduction {
    max-width: 610px;
    margin-bottom: 28px;
    color: var(--color-muted);
    font-size: 1.04rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    padding-top: 36px;
    margin-top: 38px;
    color: #7f716c;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
  }

  .account-teaser {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    padding: clamp(28px, 6vw, 70px);
    border-radius: var(--radius-lg);
  }

  .account-teaser h2 {
    max-width: 650px;
    margin-bottom: 0;
    font-size: clamp(2.2rem, 5vw, 4.6rem);
  }

  .account-teaser__links {
    display: grid;
    align-content: center;
  }

  .account-teaser__links > a:not(.text-link),
  .account-teaser__links > span {
    display: flex;
    gap: 20px;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
    font-weight: 700;
  }

  .account-teaser__links span span,
  .account-teaser__links small {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 400;
  }

  .account-teaser__links .text-link {
    margin-top: 24px;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 150px;
    }

    .hero-copy {
      max-width: 720px;
    }

    .account-teaser {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hero {
      gap: 48px;
      min-height: auto;
      padding-top: 120px;
      padding-bottom: 30px;
    }

    h1 {
      font-size: clamp(3.25rem, 14vw, 4.2rem);
    }

    .hero-meta {
      display: grid;
    }

    .account-teaser {
      gap: 34px;
      padding: 26px;
    }
  }
</style>
