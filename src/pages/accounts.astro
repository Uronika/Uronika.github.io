---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="页面已迁移｜Uronika"
  description="公开账号与联系方式已迁移至联系我页面。"
  noindex
  canonicalPath="/contact/"
  redirectTo="/contact/"
>
  <section class="redirect-page section-shell">
    <p class="eyebrow">Moved / 页面已迁移</p>
    <h1>账号信息已经并入“联系我”。</h1>
    <p>如果浏览器没有自动跳转，请使用下面的按钮。</p>
    <a class="button button--primary" href="/contact/">前往联系我</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("/contact/");
</script>

<style>
  .redirect-page {
    display: grid;
    align-content: center;
    min-height: 100svh;
    padding-block: 130px;
  }

  h1 {
    max-width: 850px;
    margin-bottom: 20px;
    font-size: clamp(2.8rem, 7vw, 6rem);
  }

  .redirect-page > p:not(.eyebrow) {
    color: var(--color-muted);
  }

  .button {
    width: max-content;
    margin-top: 18px;
  }
</style>

