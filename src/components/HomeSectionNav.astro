---
const sections = [
  { id: "home", label: "首页" },
  { id: "capabilities", label: "能力" },
  { id: "featured-works", label: "作品" },
  { id: "experience", label: "经历" },
  { id: "contact", label: "联系" }
];
---

<nav class="home-section-nav" aria-label="首页章节导航" data-home-section-nav>
  <ol>
    {
      sections.map((section, index) => (
        <li>
          <a
            href={`#${section.id}`}
            data-section-link={section.id}
            aria-label={`前往${section.label}章节`}
            aria-current={index === 0 ? "step" : undefined}
          >
            <span class="home-section-nav__label">{section.label}</span>
            <span class="home-section-nav__dot" aria-hidden="true"></span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<script>
  const navigation = document.querySelector<HTMLElement>("[data-home-section-nav]");
  const links = [...(navigation?.querySelectorAll<HTMLAnchorElement>("[data-section-link]") ?? [])];
  const sections = links.flatMap((link) => {
    const section = document.getElementById(link.dataset.sectionLink ?? "");
    return section ? [section] : [];
  });
  const ratios = new Map<Element, number>();

  const setCurrent = (sectionId: string) => {
    links.forEach((link) => {
      const active = link.dataset.sectionLink === sectionId;
      if (active) link.setAttribute("aria-current", "step");
      else link.removeAttribute("aria-current");
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => ratios.set(entry.target, entry.intersectionRatio));
      const visible = sections
        .map((section) => ({ section, ratio: ratios.get(section) ?? 0 }))
        .sort((left, right) => right.ratio - left.ratio)[0];
      if (visible && visible.ratio > 0) setCurrent(visible.section.id);
    },
    { threshold: [0, 0.15, 0.3, 0.5, 0.75] }
  );

  sections.forEach((section) => observer.observe(section));
  links.forEach((link) => link.addEventListener("click", () => setCurrent(link.dataset.sectionLink ?? "home")));
</script>

<style>
  .home-section-nav {
    position: fixed;
    z-index: 80;
    top: 50%;
    right: 24px;
    transform: translateY(-50%);
  }

  ol {
    display: grid;
    gap: 8px;
    padding: 10px 8px;
    margin: 0;
    list-style: none;
    background: rgba(17, 12, 13, 0.62);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(18px);
  }

  a {
    position: relative;
    display: grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border-radius: 50%;
  }

  .home-section-nav__dot {
    width: 6px;
    height: 6px;
    background: #796963;
    border-radius: 50%;
    transition: width 180ms ease, height 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  a:hover .home-section-nav__dot,
  a[aria-current="step"] .home-section-nav__dot {
    width: 10px;
    height: 10px;
    background: var(--color-ember);
    box-shadow: 0 0 18px rgba(255, 107, 53, 0.8);
  }

  .home-section-nav__label {
    position: absolute;
    top: 50%;
    right: 42px;
    padding: 5px 9px;
    color: var(--color-text);
    background: rgba(17, 12, 13, 0.86);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    opacity: 0;
    pointer-events: none;
    transform: translate(8px, -50%);
    transition: opacity 160ms ease, transform 160ms ease;
    white-space: nowrap;
  }

  a:hover .home-section-nav__label,
  a:focus-visible .home-section-nav__label {
    opacity: 1;
    transform: translate(0, -50%);
  }

  @media (max-width: 980px) {
    .home-section-nav {
      display: none;
    }
  }
</style>

